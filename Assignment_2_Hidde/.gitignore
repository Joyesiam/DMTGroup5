# Raw + processed data (too large for git)
data/raw/
data/processed/
*.parquet
*.feather

# Model artifacts
data/processed/models/
*.pkl
*.joblib

# Python
__pycache__/
*.pyc
.ipynb_checkpoints/

# Jupyter notebook outputs we don't want committed when generated by jupytext
# (We DO commit the executed notebooks themselves)

# LaTeX intermediates (keep .tex, .bib, .pdf)
report/*.aux
report/*.log
report/*.blg
report/*.bbl
report/*.fdb_latexmk
report/*.fls
report/*.out
report/*.synctex.gz
report/*.toc

# Large CSV outputs except the final submission
results/*.csv
!results/submission.csv

# OS junk
.DS_Store

# Internal scratch (subagent review notes etc.)
notes/00_method_hint.md
notes/_review_*.md
